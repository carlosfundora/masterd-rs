# MASTERd Shell — environment variable template
# Copy to .env.local and fill in your values.
# None of these are required when running inside the live Tauri desktop runtime.

# Optional: override the Tauri backend URL during development
# Optional: Gemini API key if using AI Studio integration
# GEMINI_API_KEY=your_key_here

# Optional: override the app URL for OAuth callbacks
# APP_URL=http://localhost:3000
