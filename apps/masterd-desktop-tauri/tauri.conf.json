{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MASTERd",
  "version": "0.1.0",
  "identifier": "com.masterd.desktop",
  "build": {
    "frontendDist": "../masterd-shell/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "./dev-shell.sh",
    "beforeBuildCommand": "./build-shell.sh"
  },
  "app": {
    "windows": [
      {
        "title": "MASTERd",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright (c) 2026 Carlos Fundora",
    "license": "MIT",
    "licenseFile": "../../LICENSE",
    "resources": {
      "binaries/meilisearch": "bin/meilisearch",
      "binaries/valkey-server": "bin/valkey-server",
      "binaries/falkordb-server": "bin/falkordb-server",
      "binaries/model2vec-service": "bin/model2vec-service",
      "modules/falkordb.so": "modules/falkordb.so",
      "../../services/searxng-service": "services/searxng-service",
      "../../services/colbert-service": "services/colbert-service",
      "../../services/jina-service": "services/jina-service",
      "../../services/jina-v5-service": "services/jina-v5-service",
      "../../models/jina-v5-omni-nano-gguf": "models/jina-v5-omni-nano-gguf",
      "../../models/jina-v5-omni-small-gguf": "models/jina-v5-omni-small-gguf"
    },
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {}
    }
  }
}
